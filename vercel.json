{
  "rewrites": [
    { "source": "/snapscored", "destination": "/api/snapscored" },
    { "source": "/snapscored/(.*)", "destination": "/api/snapscored" },
    { "source": "/snapunks", "destination": "/api/snapunks" },
    { "source": "/snapunks/(.*)", "destination": "/api/snapunks" },
    { "source": "/", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.ts": { "memory": 256 },
    "api/snapscored.ts": { "memory": 256 },
    "api/snapunks.ts": { "memory": 256 }
  },
  "framework": null
}
